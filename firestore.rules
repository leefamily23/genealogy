rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the caller's role from the users collection
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper: caller is signed in AND has role editor or admin
    function isEditorOrAdmin() {
      return request.auth != null && getRole() in ['editor', 'admin'];
    }

    // Helper: caller is signed in AND has role admin
    function isAdmin() {
      return request.auth != null && getRole() == 'admin';
    }

    // family: public read, editor/admin write
    match /family/{memberId} {
      allow read:  if true;
      allow write: if isEditorOrAdmin();
    }

    // users: more nuanced rules to allow activation while maintaining security
    match /users/{userId} {
      // Admins can read/write all users
      allow read, write: if isAdmin();
      
      // Authenticated users can read their own record or pending invites by email
      allow read: if request.auth != null && (
        userId == request.auth.uid || 
        userId == request.auth.token.email
      );
      
      // Authenticated users can create/update their own record (for activation)
      allow create, update: if request.auth != null && userId == request.auth.uid;
      
      // Authenticated users can delete pending invites with their email (for activation cleanup)
      allow delete: if request.auth != null && userId == request.auth.token.email;
    }

    // editHistory: signed-in read, editor/admin write
    match /editHistory/{entryId} {
      allow read:  if request.auth != null;
      allow write: if isEditorOrAdmin();
    }
  }
}
