rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // TEMPORARY: Allow authenticated users to read/write users collection for initial setup
    // TODO: Restore secure rules after first admin is created
    
    // family: public read, authenticated write (temporary)
    match /family/{memberId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // users: authenticated read/write (temporary - for initial admin setup)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // editHistory: signed-in read/write
    match /editHistory/{entryId} {
      allow read, write: if request.auth != null;
    }
  }
}

